# Kopie nach `.env.local` (nicht committen). Siehe `docs/KUNDEN-HANDBUCH.md` → Figma → Code.

# Figma REST API: Settings → Account → Personal access tokens
FIGMA_ACCESS_TOKEN=

# Optional: anderes File als GreenLine-Build
# FIGMA_FILE_KEY=5chhaCONWAzGuiTeptCpEu

# Optional: Header-Bilder überschreiben (Default ohne .env: Logo 377-817, Profil 377-818)
# FIGMA_FRAME60_LOGO_NODE_ID=377-817
# FIGMA_FRAME60_AVATAR_NODE_ID=377-818
# Frame 60 Knotenbaum: npm run figma:inspect-frame60

# Frame 59 (Fläche erfassen): PNG @2x via npm run figma:pull-capture
# Standard: AR-Karte = 25-90, Foto-Icon = 130-72, grüne Check-Kachel = Gruppe 21-15 (nicht 21-11 — PNG leer)
# FIGMA_CAPTURE_AR_NODE_ID=25-90
# FIGMA_CAPTURE_UPLOAD_NODE_ID=130-72
# FIGMA_CAPTURE_CHECK_NODE_ID=21-15

# Analyse-Seite /analyse (Frame 358-26): Hero-Bild node 26-91
# npm run figma:pull-analysis
# FIGMA_ANALYSIS_HERO_NODE_ID=26-91

# Feature-Auswahl /feature-auswahl (Frame 377-1649): npm run figma:pull-feature-selection
# Großes Bild „Ausgangszustand“: 26-92
# FIGMA_FEATURE_HERO_AUSGANG_NODE_ID=26-92
# Standard: 26-94 Terrasse, 26-95 Rollrasen, 26-96 Gartenhaus, 26-98 Brunnen, 358-137 Gartenweg, 23-13 Haken
# FIGMA_FEATURE_THUMB_TERRASSE_NODE_ID=26-94
# FIGMA_FEATURE_THUMB_ROLLRASEN_NODE_ID=26-95
# FIGMA_FEATURE_THUMB_GARTENHAUS_NODE_ID=26-96
# FIGMA_FEATURE_THUMB_BRUNNEN_NODE_ID=26-98
# FIGMA_FEATURE_THUMB_GARTENWEG_NODE_ID=358-137
